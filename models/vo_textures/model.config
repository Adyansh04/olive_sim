<?xml version="1.0"?>
<model>
  <name>vo_textures</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>
  <description>
    Texture container for maze world surfaces (floor, walls, paintings).
    Not spawned directly - referenced by albedo_map paths so the maze
    presents trackable features for the monocular visual-odometry front-end.
  </description>
</model>
