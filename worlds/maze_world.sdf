    <!-- 3D props: textured crates / pillars / barrel giving the monocular
         camera non-coplanar structure (well-conditioned essential matrix).
         All sit inside the +-7 drive ring with >1 m clearance, clear of the
         interior walls, the spawn (-6,-6), and the marker sightlines. -->
    <include>
      <uri>model://crate</uri>
      <name>prop_crate_ne</name>
      <pose>5.8 5.8 0.25 0 0 0.5</pose>
    </include>

    <include>
      <uri>model://pillar</uri>
      <name>prop_pillar_nw</name>
      <pose>-5.8 5.8 0.6 0 0 0</pose>
    </include>

    <include>
      <uri>model://barrel</uri>
      <name>prop_barrel_se</name>
      <pose>5.8 -5.8 0.425 0 0 0</pose>
    </include>

    <include>
      <uri>model://pillar</uri>
      <name>prop_pillar_e</name>
      <pose>5.8 -1.0 0.6 0 0 0</pose>
    </include>

    <include>
      <uri>model://crate</uri>
      <name>prop_crate_n</name>
      <pose>-2.0 5.8 0.25 0 0 -0.4</pose>
    </include>

    <include>
      <uri>model://barrel</uri>
      <name>prop_barrel_mid</name>
      <pose>2.5 2.5 0.425 0 0 0</pose>
    </include>

    <!-- Plain white backing panels behind each marker: the textured walls
         drown out the WhyCode pattern (dark ring lost in the brick mortar),
         so each marker gets a matte-white board to segment against. Yaw
         matches the marker so the panel faces the interior; sized to fit the
         corner triangle without poking through the boundary walls. -->
    <model name="marker_backing_0">
      <static>true</static>
      <pose>7.585 7.585 1.2 0 0 -2.356</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.05 0.9 1.0</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient><diffuse>1 1 1 1</diffuse><specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="marker_backing_1">
      <static>true</static>
      <pose>-7.585 7.585 1.2 0 0 2.356</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.05 0.9 1.0</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient><diffuse>1 1 1 1</diffuse><specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="marker_backing_2">
      <static>true</static>
      <pose>-7.585 -7.585 1.2 0 0 0.785</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.05 0.9 1.0</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient><diffuse>1 1 1 1</diffuse><specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="marker_backing_3">
      <static>true</static>
      <pose>7.585 -7.585 1.2 0 0 -0.785</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.05 0.9 1.0</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient><diffuse>1 1 1 1</diffuse><specular>0.02 0.02 0.02 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- WhyCode Markers -->
    <include>
      <uri>model://whycode_0</uri>
      <name>marker_0</name>
      <pose>7.5 7.5 1.2 0 0 -2.356</pose>
    </include>

    <include>
      <uri>model://whycode_1</uri>
      <name>marker_1</name>
      <pose>-7.5 7.5 1.2 0 0 2.356</pose>
    </include>

    <include>
      <uri>model://whycode_2</uri>
      <name>marker_2</name>
      <pose>-7.5 -7.5 1.2 0 0 0.785</pose>
    </include>

    <include>
      <uri>model://whycode_3</uri>
      <name>marker_3</name>
      <pose>7.5 -7.5 1.2 0 0 -0.785</pose>
    </include>

  </world>
</sdf>
