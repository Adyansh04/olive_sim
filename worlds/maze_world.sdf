    <!-- Wall paintings: high-contrast landmarks mounted low (camera height)
         and slightly proud of the boundary walls, facing the drive ring. -->
    <model name="painting_n1">
      <static>true</static>
      <pose>-3.5 7.75 0.45 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>0.9 0.05 0.7</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse><specular>0 0 0 1</specular>
            <pbr><metal>
              <albedo_map>model://vo_textures/materials/textures/painting_1.png</albedo_map>
              <roughness>0.6</roughness><metalness>0.0</metalness>
            </metal></pbr>
          </material>
        </visual>
      </link>
    </model>

    <model name="painting_n2">
      <static>true</static>
      <pose>3.5 7.75 0.45 0 0 0</pose>
      <link name="link">
